<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background rounded rectangle -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0F766E" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Piggy body (large oval) -->
    <item>
        <shape android:shape="oval">
            <size android:width="72dp" android:height="56dp" />
            <solid android:color="#FFFFFF" />
        </shape>
        <inset android:top="18dp" android:left="28dp" android:right="28dp" android:bottom="28dp" />
    </item>

    <!-- Piggy head (small oval) -->
    <item>
        <shape android:shape="oval">
            <size android:width="34dp" android:height="28dp" />
            <solid android:color="#FFFFFF" />
        </shape>
        <inset android:top="10dp" android:left="8dp" android:right="60dp" android:bottom="48dp" />
    </item>

    <!-- Snout (small oval) -->
    <item>
        <shape android:shape="oval">
            <size android:width="18dp" android:height="12dp" />
            <solid android:color="#F1F1F1" />
        </shape>
        <inset android:top="22dp" android:left="18dp" android:right="64dp" android:bottom="48dp" />
    </item>

    <!-- Eye (tiny circle) -->
    <item>
        <shape android:shape="oval">
            <size android:width="6dp" android:height="6dp" />
            <solid android:color="#0F766E" />
        </shape>
        <inset android:top="18dp" android:left="26dp" android:right="76dp" android:bottom="58dp" />
    </item>

    <!-- Leg (rectangle) -->
    <item>
        <shape android:shape="rectangle">
            <size android:width="6dp" android:height="8dp" />
            <solid android:color="#FFFFFF" />
        </shape>
        <inset android:top="58dp" android:left="40dp" android:right="86dp" android:bottom="6dp" />
    </item>
</layer-list>
